# BUSCASAM prod environment (ADR-0009 §8). Copy to `.env` on the VM (mode 0600,
# gitignored) and fill the secrets. Keep in sync with the `Settings` schema in
# backend/src/buscasam/settings.py when fields are added or removed.

# --- versioning / images ---
BUSCASAM_VERSION=latest
EMBEDDING_MODEL_ID=intfloat/multilingual-e5-large
EMBEDDING_MODEL_REVISION=             # pinned HF revision SHA (ADR-0002)

# --- postgres (db container) ---
POSTGRES_USER=buscasam
POSTGRES_PASSWORD=                     # secret
POSTGRES_DB=buscasam

# --- backend (api / workers / backup) ---
BUSCASAM_ENV=prod
BUSCASAM_DATABASE_URL=postgresql+psycopg://buscasam:CHANGEME@db:5432/buscasam
BUSCASAM_TEI_URL=http://tei
BUSCASAM_BASE_URL=https://buscasam.unsam.edu.ar
BUSCASAM_BLOB_ROOT=/var/lib/buscasam/blobs
BUSCASAM_MIN_SEMANTIC_SIMILARITY=0.78
BUSCASAM_EMBED_QUERY_TIMEOUT_S=0.5
BUSCASAM_EXTRACT_PIPELINE_VERSION=extract-v2
BUSCASAM_SECRET_KEY=                   # secret (ADR-0005)
BUSCASAM_OIDC_CLIENT_ID=               # secret
BUSCASAM_OIDC_CLIENT_SECRET=           # secret

# --- metadata LLM (optional, infra/metadata-llm) ---
BUSCASAM_METADATA_LLM_ENABLED=0
BUSCASAM_METADATA_LLM_URL=http://localhost:11434
BUSCASAM_METADATA_LLM_MODEL=qwen2.5:7b-instruct

# --- nginx / TLS (ADR-0009 §9) ---
TLS_MODE=upstream                      # upstream (GCP HTTPS LB) | self
SERVER_NAME=buscasam.unsam.edu.ar
# Comma/space-separated; GCP HTTPS LB front-end ranges (used only in upstream).
TRUSTED_PROXY_CIDR=130.211.0.0/22,35.191.0.0/16
